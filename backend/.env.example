# Configuración de Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=foro_universitario
PORT=3000

# Código especial para registrar administradores y secretarias
# ⚠️ Cambiar por un código seguro antes de desplegar
ADMIN_REGISTRATION_CODE=CAMBIAR_ESTO

# Configuración de sesiones
SESSION_SECRET=clave_muy_larga_y_aleatoria_para_produccion

# Configuración de archivos
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Configuración de email (para recuperación de contraseña)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion

# Entorno
NODE_ENV=development

# Configuración de votaciones
VOTE_COOLDOWN=1000
DAILY_VOTE_LIMIT=0
ENABLE_VOTE_LOGGING=true
